        heightSliderBtn.Position = UDim2.new(percent, -7, 0.5, -7)
        updateHeightFromSlider(percent)
        draggingHeight = true
    end
end)

RunService.RenderStepped:Connect(function()
    if draggingDelay then
        local mousePos = UserInputService:GetMouseLocation()
        local relativeX = math.clamp(mousePos.X - delaySliderBg.AbsolutePosition.X, 0, delaySliderBg.AbsoluteSize.X)
        local percent = relativeX / delaySliderBg.AbsoluteSize.X
        delaySliderBtn.Position = UDim2.new(percent, -7, 0.5, -7)
        updateDelayFromSlider(percent)
    end
    if draggingHeight then
        local mousePos = UserInputService:GetMouseLocation()
        local relativeX = math.clamp(mousePos.X - heightSliderBg.AbsolutePosition.X, 0, heightSliderBg.AbsoluteSize.X)
        local percent = relativeX / heightSliderBg.AbsoluteSize.X
        heightSliderBtn.Position = UDim2.new(percent, -7, 0.5, -7)
        updateHeightFromSlider(percent)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingDelay = false
        draggingHeight = false
    end
end)

