local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local player = Players.LocalPlayer

local autoJumpEnabled = false
local jumpPower = 20
local jumpDelay = 0.5
local lastJumpTime = 0
local jumpConnection = nil

local function doJump()
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum and hum.Health > 0 and not hum.Sit then
        hum.JumpPower = jumpPower
        hum:ChangeState(Enum.HumanoidStateType.Jumping)
        lastJumpTime = tick()
    end
end

local function updateLoop()
    if not autoJumpEnabled then return end
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    local grounded = hum.FloorMaterial ~= Enum.Material.Air
    if grounded and tick() - lastJumpTime >= jumpDelay then
        doJump()
    end
end

local function startAutoJump()
    if jumpConnection then return end
    lastJumpTime = tick() - jumpDelay
    jumpConnection = RunService.Heartbeat:Connect(updateLoop)
end

local function stopAutoJump()
    if jumpConnection then
        jumpConnection:Disconnect()
        jumpConnection = nil
    end
end

