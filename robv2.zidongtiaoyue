local draggingDelay = false
local draggingHeight = false

local function updateDelayFromSlider(percent)
    percent = math.clamp(percent, 0, 1)
    jumpDelay = 0.01 + percent * 9.99
    delayLabel.Text = "延迟: " .. string.format("%.2f", jumpDelay) .. "s"
end

local function updateHeightFromSlider(percent)
    percent = math.clamp(percent, 0, 1)
    jumpPower = math.floor(1 + percent * 499)
    heightLabel.Text = "高度: " .. jumpPower
end

local function setSliderPositions()
    task.wait(0.05)
    if delaySliderBg.AbsoluteSize.X > 0 then
        local delayPercent = (jumpDelay - 0.01) / 9.99
        delaySliderBtn.Position = UDim2.new(delayPercent, -7, 0.5, -7)
    end
    if heightSliderBg.AbsoluteSize.X > 0 then
        local heightPercent = (jumpPower - 1) / 499
        heightSliderBtn.Position = UDim2.new(heightPercent, -7, 0.5, -7)
    end
end

local function onDelayDrag(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingDelay = true
        local mousePos = UserInputService:GetMouseLocation()
        local relativeX = math.clamp(mousePos.X - delaySliderBg.AbsolutePosition.X, 0, delaySliderBg.AbsoluteSize.X)
        local percent = relativeX / delaySliderBg.AbsoluteSize.X
        delaySliderBtn.Position = UDim2.new(percent, -7, 0.5, -7)
        updateDelayFromSlider(percent)
    end
end

local function onHeightDrag(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingHeight = true
        local mousePos = UserInputService:GetMouseLocation()
        local relativeX = math.clamp(mousePos.X - heightSliderBg.AbsolutePosition.X, 0, heightSliderBg.AbsoluteSize.X)
        local percent = relativeX / heightSliderBg.AbsoluteSize.X
        heightSliderBtn.Position = UDim2.new(percent, -7, 0.5, -7)
        updateHeightFromSlider(percent)
    end
end

delaySliderBtn.InputBegan:Connect(onDelayDrag)
heightSliderBtn.InputBegan:Connect(onHeightDrag)

delaySliderBg.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        local mousePos = input.Position
        local relativeX = math.clamp(mousePos.X - delaySliderBg.AbsolutePosition.X, 0, delaySliderBg.AbsoluteSize.X)
        local percent = relativeX / delaySliderBg.AbsoluteSize.X
        delaySliderBtn.Position = UDim2.new(percent, -7, 0.5, -7)
        updateDelayFromSlider(percent)
        draggingDelay = true
    end
end)

heightSliderBg.InputBegan:Connect(function(input, gpe)
