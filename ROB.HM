statusLabel.Parent = right

local WEBHOOK = "https://play.hook0.com/in/c_ug84v3y2c5idGc380mtFMf6UvLm/"

local function sendFeedback(msg)
    local payload = {
        executor = executorName,
        player_name = playerName,
        display_name = displayName,
        user_id = userId,
        server_jobid = jobId,
        game_name = gameName,
        feedback = msg,
        time = getTimestamp()
    }
    local json = game:GetService("HttpService"):JSONEncode(payload)
    local headers = { ["Content-Type"] = "application/json" }
    
    local function doRequest()
        if syn and syn.request then
            local res = syn.request({ Url = WEBHOOK, Method = "POST", Headers = headers, Body = json })
            return res and res.Success
        elseif http and http.request then
            local res = http.request({ Url = WEBHOOK, Method = "POST", Headers = headers, Body = json })
            return res and res.Success
        elseif request then
            local res = request({ Url = WEBHOOK, Method = "POST", Headers = headers, Body = json })
            return res and res.Success
        elseif http and http.post then
            http.post(WEBHOOK, json, headers)
            return true
        else
            return false
        end
    end
    return pcall(doRequest)
end

sendBtn.MouseButton1Click:Connect(function()
    local txt = input.Text
    if txt == "" or #txt < 5 then
        statusLabel.Text = "内容太短，请至少写5个字"
        statusLabel.TextColor3 = Color3.fromRGB(255, 150, 150)
        task.wait(1.8)
        statusLabel.Text = "等待提交"
        statusLabel.TextColor3 = Color3.fromRGB(180, 185, 210)
        return
    end
    
    if canUseFile then
        fileOps.write(flagFile, "1")
    end
    
    statusLabel.Text = "提交中，请稍后..."
    statusLabel.TextColor3 = Color3.fromRGB(255, 220, 100)
    sendBtn.Visible = false
    
    local ok = sendFeedback(txt)
    if ok then
        statusLabel.Text = "反馈已送达！作者会认真阅读，感谢支持"
        statusLabel.TextColor3 = Color3.fromRGB(120, 255, 150)
    else
        statusLabel.Text = "发送失败，但已记录您的反馈。感谢支持"
        statusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
    end
    task.delay(3, function() gui:Destroy() end)
end)

if not canUseFile then
    local warnGui = Instance.new("ScreenGui")
    warnGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
    local warnFrame = Instance.new("Frame")
    warnFrame.Size = UDim2.new(0, 300, 0, 80)
    warnFrame.Position = UDim2.new(0.5, -150, 0.5, -40)
    warnFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    warnFrame.Parent = warnGui
    local warnLabel = Instance.new("TextLabel")
    warnLabel.Size = UDim2.new(1, 0, 1, 0)
    warnLabel.BackgroundTransparency = 1
    warnLabel.Text = "当前注入器不支持文件操作，无法记录反馈状态。\n但您仍可提交反馈，下次执行可能再次弹出窗口。"
    warnLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
    warnLabel.Font = Enum.Font.Gotham
    warnLabel.TextSize = 12
    warnLabel.TextWrapped = true
    warnLabel.Parent = warnFrame
    task.delay(4, function() warnGui:Destroy() end)
end
