local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local userId = LocalPlayer.UserId
local flagFile = "feedback_" .. userId .. ".txt"

local fileOps = { exists = false, write = false }

local function checkFileOps()
    if isfile and writefile then
        fileOps.exists = isfile
        fileOps.write = writefile
        return true
    elseif file_exists and write_file then
        fileOps.exists = file_exists
        fileOps.write = write_file
        return true
    elseif readfile and (writefile or savefile) then
        fileOps.exists = function(name) return pcall(readfile, name) end
        fileOps.write = writefile or savefile
        return true
    end
    return false
end

local canUseFile = checkFileOps()

if canUseFile and fileOps.exists(flagFile) then
    return
end

