local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local HttpService = game:GetService("HttpService")
local MarketplaceService = game:GetService("MarketplaceService")
local RunService = game:GetService("RunService")

local function safeGet(fn, default)
    local ok, res = pcall(fn)
    if ok then return res end
    return default
end

local jobId = safeGet(function() return game.JobId end, "无")
local placeId = safeGet(function() return game.PlaceId end, 0)
local userId = safeGet(function() return LocalPlayer.UserId end, 0)
local playerName = safeGet(function() return LocalPlayer.Name end, "未知")
local displayName = safeGet(function() return LocalPlayer.DisplayName end, "未知")
local timestamp = os.date("%Y-%m-%d %H:%M:%S")

local executorName = "未知"
local executors = {
    {check = function() return syn and syn.getexecutorname end, name = syn and syn.getexecutorname and syn.getexecutorname()},
    {check = function() return getexecutorname end, name = getexecutorname and getexecutorname()},
    {check = function() return identifyexecutor end, name = identifyexecutor and identifyexecutor()},
    {check = function() return KRNL_LOADED end, name = "Krnl"},
    {check = function() return is_sirhurt_closure end, name = "Sirhurt"},
    {check = function() return Fluxus end, name = "Fluxus"},
    {check = function() return Electron end, name = "Electron"}
}
for _, e in ipairs(executors) do
    local ok, val = pcall(e.check)
    if ok and val then
        if type(val) == "function" then
            local nameOk, nameVal = pcall(val)
            if nameOk and nameVal and nameVal ~= "" then
                executorName = nameVal
                break
            end
        else
            executorName = e.name
            break
        end
    end
end

local gameChineseName = "未知游戏"
local gameEnglishName = safeGet(function() return game.Name end, "未知")
local infoSuccess, info = pcall(function() return MarketplaceService:GetProductInfo(placeId) end)
if infoSuccess and info then
    gameChineseName = info.Name or game.Name
end

