    getgenv().wow_InstantRespawn = wow_bool
    if wow_bool then
        wow_lastDeathPos = nil
        wow_isRespawning = false
        wow_isSelfInflictedDeath = false
        wow_setupRespawn()
    else
        wow_lastDeathPos = nil
        wow_isSelfInflictedDeath = false
    end
end)
wow_Group2Tab:Toggle("防击飞", function(wow_bool)
    getgenv().wow_AntiPush = wow_bool
    if wow_bool then
        local Players = game:GetService("Players")
        local plr = Players.LocalPlayer
        local function protect(char)
            for _,v in ipairs(char:GetDescendants()) do
                if v:IsA("BodyVelocity") or v:IsA("BodyForce") or v:IsA("LinearVelocity") or v:IsA("VectorForce") then
                    v:Destroy()
                end
            end
            local connection
            connection = char.DescendantAdded:Connect(function(v)
                if v:IsA("BodyVelocity") or v:IsA("BodyForce") or v:IsA("LinearVelocity") or v:IsA("VectorForce") then
                    task.wait()
                    if v.Parent then
                        v:Destroy()
                    end
                end
                if not getgenv().wow_AntiPush and connection then
                    connection:Disconnect()
                end
            end)
        end
        if plr.Character then
            protect(plr.Character)
        end
        local charAddedConnection
        charAddedConnection = plr.CharacterAdded:Connect(function(char)
            protect(char)
            if not getgenv().wow_AntiPush and charAddedConnection then
                charAddedConnection:Disconnect()
            end
        end)
    else
    end
end)
