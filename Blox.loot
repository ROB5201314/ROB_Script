for _,p in ipairs(wow_Players:GetPlayers()) do
    if p ~= wow_LocalPlayer then
        table.insert(wow_list, p.Name)
    end
end

local wow_dropdown = wow_Group4Tab:Dropdown("选择目标玩家", wow_list, function(v)
