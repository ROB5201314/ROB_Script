getgenv().wow_AutoCollect = false
getgenv().wow_CollectRange = 100
local wow_collectThread
local function wow_findLootContainer()
    local wow_runtime = workspace:FindFirstChild("Runtime")
    local wow_loot = wow_runtime and wow_runtime:FindFirstChild("LootPoints")
    return wow_loot or workspace:FindFirstChild("LootPoints")
end

local function wow_collectLoop()
    while task.wait(0.025) do
        if not getgenv().wow_AutoCollect then break end
        local wow_character = wow_LocalPlayer.Character
        if not wow_character then continue end
        local wow_rootPart = wow_character:FindFirstChild("HumanoidRootPart")
        if not wow_rootPart then continue end
        local wow_lootContainer = wow_findLootContainer()
        if not wow_lootContainer then continue end
        for _,wow_obj in ipairs(wow_lootContainer:GetDescendants()) do
            if wow_obj:IsA("ProximityPrompt") then
                local wow_parent = wow_obj.Parent
                if not (wow_parent and wow_parent:IsA("BasePart")) then continue end
                local wow_dist = (wow_parent.Position - wow_rootPart.Position).Magnitude
                if wow_dist <= getgenv().wow_CollectRange then fireproximityprompt(wow_obj) end
            end
        end
    end
end
local vu = game:GetService("VirtualUser")
local PlayerGui = wow_LocalPlayer:WaitForChild("PlayerGui")
local function wow_antiAFK()
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "AntiAFKGui"
    ScreenGui.Parent = PlayerGui
    local Frame = Instance.new("Frame")
    Frame.Size = UDim2.new(0, 200, 0, 60)
    Frame.Position = UDim2.new(1, -210, 1, -70)
    Frame.BackgroundColor3 = Color3.new(0.1, 0.1, 0.1)
    Frame.BackgroundTransparency = 0.2
    Frame.BorderSizePixel = 0
    Frame.ClipsDescendants = true
    Frame.Parent = ScreenGui
    local TextLabel = Instance.new("TextLabel")
    TextLabel.Size = UDim2.new(1, 0, 1, 0)
    TextLabel.BackgroundTransparency = 1
    TextLabel.Text = "防挂机已运行"
    TextLabel.TextColor3 = Color3.new(0, 1, 0)
    TextLabel.Font = Enum.Font.SourceSansBold
    TextLabel.TextSize = 18
    TextLabel.TextWrapped = true
    TextLabel.Parent = Frame
    local function fadeOut()
        task.wait(4)
        for i = 0, 1, 0.05 do
            Frame.BackgroundTransparency = 0.2 + i * 0.8
            TextLabel.TextTransparency = i
            task.wait(0.05)
        end
        Frame:Destroy()
    end
    task.delay(0.1, fadeOut)
    wow_LocalPlayer.Idled:Connect(function()
        vu:Button2Down(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
        task.wait(1)
        vu:Button2Up(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
    end)
end
wow_Group1Tab:Button("启动防挂机", function()
    wow_antiAFK()
end)

wow_Group1Tab:Toggle("自动拾取(抢装备)", function(wow_bool)
    getgenv().wow_AutoCollect = wow_bool
    if wow_bool then
        wow_collectThread = task.spawn(wow_collectLoop)
    else
        if wow_collectThread then task.cancel(wow_collectThread) end
    end
end)

local wow_fpsGui = nil
local wow_fpsConn = nil
local wow_dragConn = nil
local wow_UserInputService = game:GetService("UserInputService")

wow_Group1Tab:Toggle("FPS帧数", function(wowBool)
    if not wowBool then
        if wow_fpsConn then wow_fpsConn:Disconnect() wow_fpsConn = nil end
        if wow_dragConn then wow_dragConn:Disconnect() wow_dragConn = nil end
        if wow_fpsGui then wow_fpsGui:Destroy() wow_fpsGui = nil end
        return
    end
    wow_fpsGui = Instance.new("ScreenGui")
    wow_fpsGui.ResetOnSpawn = false
    wow_fpsGui.Parent = wow_LocalPlayer:WaitForChild("PlayerGui")
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0,140,0,40)
    frame.Position = UDim2.new(1,-160,0,20)
    frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
    frame.BorderSizePixel = 0
    frame.Active = true
    frame.Parent = wow_fpsGui
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0,8)
    corner.Parent = frame
    local text = Instance.new("TextLabel")
    text.Size = UDim2.new(1,0,1,0)
    text.BackgroundTransparency = 1
    text.Text = "FPS: 0"
    text.TextColor3 = Color3.fromRGB(0,255,120)
    text.Font = Enum.Font.GothamBold
    text.TextSize = 16
    text.Parent = frame
    local dragging = false
    local dragStart
    local startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)
    frame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    wow_dragConn = wow_UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
    local frames = 0
    local last = tick()
    wow_fpsConn = wow_RunService.RenderStepped:Connect(function()
        frames += 1
        local now = tick()
        if now - last >= 1 then
            text.Text = "FPS: "..frames
            frames = 0
            last = now
        end
    end)
end)
wow_Group1Tab:Toggle("减少服务器卡顿", function(state)
    wow_RemoveParticlesEnabled = state
    
    if state then
        local function deleteAllParticlesAndLights()
            for _, obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("ParticleEmitter") or 
                   obj:IsA("Smoke") or 
                   obj:IsA("Fire") or 
                   obj:IsA("Sparkles") or 
                   obj:IsA("Trail") or
                   obj:IsA("Beam") then
                    obj:Destroy()
                end
            end
            
            local lighting = game:GetService("Lighting")
            lighting.GlobalShadows = false
            lighting.ShadowSoftness = 0
            
            if lighting:FindFirstChild("BloomEffect") then lighting.BloomEffect:Destroy() end
            if lighting:FindFirstChild("BlurEffect") then lighting.BlurEffect:Destroy() end
            if lighting:FindFirstChild("SunRaysEffect") then lighting.SunRaysEffect:Destroy() end
            if lighting:FindFirstChild("DepthOfFieldEffect") then lighting.DepthOfFieldEffect:Destroy() end
        end
        
        deleteAllParticlesAndLights()
        
        wow_ParticlesRemovingConnection = workspace.DescendantAdded:Connect(function(obj)
            if obj:IsA("ParticleEmitter") or 
               obj:IsA("Smoke") or 
               obj:IsA("Fire") or 
               obj:IsA("Sparkles") or 
               obj:IsA("Trail") or
               obj:IsA("Beam") then
                task.wait(0.1)
                obj:Destroy()
            end
        end)
    else
        if wow_ParticlesRemovingConnection then
            wow_ParticlesRemovingConnection:Disconnect()
            wow_ParticlesRemovingConnection = nil
        end
        
        local lighting = game:GetService("Lighting")
        lighting.GlobalShadows = true
        lighting.ShadowSoftness = 0.5
    end
end)
wow_Group1Tab:Button("关闭ui粒子效果", function()
    if wow_UI then
        wow_UI:ToggleParticles(false)
    end
end)
local wow_Group2Tab = wow_MainWindow:Tab("攻击功能", false)
local wow_walkSpeed = 16
local wow_speedThread
local function wow_maintainWalkSpeed(wow_speed)
    while task.wait(0.1) do
        local wow_char = wow_LocalPlayer.Character
        if wow_char then
            local wow_hum = wow_char:FindFirstChildOfClass("Humanoid")
            if wow_hum then wow_hum.WalkSpeed = wow_speed end
        end
    end
end
wow_Group2Tab:Textbox("步行速度", "", function(wow_text)
    local wow_speed = tonumber(wow_text)
    if wow_speed and wow_speed>=1 and wow_speed<=500 then
        wow_walkSpeed = wow_speed
        if wow_speedThread then task.cancel(wow_speedThread) end
        wow_speedThread = task.spawn(function() wow_maintainWalkSpeed(wow_speed) end)
    end
end)
wow_Group2Tab:Toggle("无限跳", function(wow_bool)
    getgenv().wow_InfiniteJump = wow_bool
    if wow_bool then
        local UIS = game:GetService("UserInputService")
        local Players = game:GetService("Players")
        local plr = Players.LocalPlayer
        local infiniteJumpConnection
        infiniteJumpConnection = UIS.JumpRequest:Connect(function()
            if plr.Character and getgenv().wow_InfiniteJump then
                local humanoid = plr.Character:FindFirstChildOfClass("Humanoid")
                if humanoid and humanoid:GetState() ~= Enum.HumanoidStateType.Dead then
                    humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                end
            end
            if not getgenv().wow_InfiniteJump and infiniteJumpConnection then
                infiniteJumpConnection:Disconnect()
            end
        end)
    else
    end
end)
wow_speedThread = task.spawn(function() wow_maintainWalkSpeed(wow_walkSpeed) end)
local wow_isAttacking = false
local wow_attackTask = nil
wow_Group2Tab:Toggle("自动攻击", function(wow_bool)
    wow_isAttacking = wow_bool
    if wow_bool then
        wow_attackTask = task.spawn(function()
            while wow_isAttacking do
                local wow_events = wow_ReplicatedStorage.Events
                local wow_attackNames = {"SwingTool","UseTool","Attack","Hit","Damage","Swing","SwingShovel","Dig","Mine","Chop","ToolAction","ActivateTool","SwingWeapon"}
                for _,wow_name in pairs(wow_attackNames) do
                    local wow_event = wow_events:FindFirstChild(wow_name)
                    if wow_event then pcall(function() wow_event:FireServer() end) end
                end
                local wow_character = wow_LocalPlayer.Character
                if wow_character then
                    for _,wow_tool in pairs(wow_character:GetChildren()) do
                        if wow_tool:IsA("Tool") then pcall(function() wow_tool:Activate() end) end
                    end
                end
                task.wait(0.05)
            end
        end)
    else
        if wow_attackTask then task.cancel(wow_attackTask) wow_attackTask = nil end
    end
end)
local wow_lastDeathPos = nil
local wow_isRespawning = false
local wow_isSelfInflictedDeath = false
getgenv().wow_InstantRespawn = false
local function wow_monitorDamageSource()
    while getgenv().wow_InstantRespawn do
        task.wait(0.1) 
        local wow_character = wow_LocalPlayer.Character
        if wow_character and not wow_isRespawning then
            local wow_hum = wow_character:FindFirstChildOfClass("Humanoid")
            if wow_hum then
                wow_hum.HealthChanged:Connect(function(wow_health)
                    if wow_health <= 0 then
                        local wow_damageSource = wow_hum:FindFirstChild("DamageSource") or wow_hum.Parent:FindFirstChild("DamageSource")
                        wow_isSelfInflictedDeath = not wow_damageSource or wow_damageSource.Value == wow_LocalPlayer.Name
                        local wow_root = wow_character:FindFirstChild("HumanoidRootPart")
                        if wow_root then wow_lastDeathPos = wow_root.CFrame end
                    end
                end)
            end
        end
    end
end
local function wow_setupRespawn()
    if getgenv().wow_InstantRespawn then
        wow_LocalPlayer.CharacterAdded:Connect(function(wow_character)
            if wow_lastDeathPos and wow_isSelfInflictedDeath then
                task.wait(0.05)
                wow_isRespawning = true
                local wow_root = wow_character:WaitForChild("HumanoidRootPart", 1)
                if wow_root then wow_root.CFrame = wow_lastDeathPos end
                wow_isRespawning = false
                wow_isSelfInflictedDeath = false
            end
        end)
        task.spawn(wow_monitorDamageSource)
    end
end
