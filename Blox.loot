local wow_FarmTab = wow_MainWindow:Tab("自动农场", false)
wow_FarmTab:Label("挂机刷boss收集(打凋零开启防击飞和原地重生)")
local wow_autoEnabled = false
local wow_bossThread = nil
local wow_lootThread = nil
local wow_attackThread = nil
local wow_hasTeleported = false
local wow_followConn = nil

local wow_autoDiamondEnabled = false
local wow_diamondBossThread = nil
local wow_diamondAttackThread = nil
local wow_diamondFollowConn = nil
local wow_diamondHasTeleported = false

local wow_respawnPositionsServer1 = {
    ["1_2_100"] = Vector3.new(-112, 37, 18),
    ["1_2_101"] = Vector3.new(-74, 45, -123),
    ["1_3_100"] = Vector3.new(-18, 84, -457),
    ["1_4_100"] = Vector3.new(-30, 144, -634)
}

local wow_respawnPositionsServer2 = {
    ["2_1_100"] = Vector3.new(65, -4, -67),
    ["2_2_100"] = Vector3.new(65, -17, -398),
    ["2_3_100"] = Vector3.new(59, -39, -833),
    ["2_4_100"] = Vector3.new(56, 40, -1013)
}
local wow_respawnPositionsServer3 = {
    ["3_1_100"] = Vector3.new(71, -38, -69)
}

local function wow_getRespawnPosition(wow_bossName)
    if game.PlaceId == 120704669141193 then
        return wow_respawnPositionsServer1[wow_bossName]
    elseif game.PlaceId == 116463652873308 then
        return wow_respawnPositionsServer2[wow_bossName]
    elseif game.PlaceId == 81256750655373 then
        return wow_respawnPositionsServer3[wow_bossName]
    end
    return nil
end

local function wow_checkBossExists()
    if not wow_TARGETS_LIST then return false end
    for _, wow_bossInfo in ipairs(wow_TARGETS_LIST) do
        local wow_current = workspace
        for _, wow_folderName in ipairs(wow_bossInfo.path) do
            wow_current = wow_current:FindFirstChild(wow_folderName)
            if not wow_current then break end
        end
        if wow_current and wow_current:IsA("Model") then
            return true
        end
    end
    return false
end

local function wow_findBoss()
    if not wow_TARGETS_LIST then return nil end
    for _, wow_bossInfo in ipairs(wow_TARGETS_LIST) do
        local wow_current = workspace
        for _, wow_folderName in ipairs(wow_bossInfo.path) do
            wow_current = wow_current:FindFirstChild(wow_folderName)
            if not wow_current then break end
        end
        if wow_current and wow_current:IsA("Model") then
            return wow_current, wow_bossInfo.path[#wow_bossInfo.path]
        end
    end
    return nil
end

local function wow_findLootFolderAuto()
    local wow_runtime = workspace:FindFirstChild("Runtime")
    return (wow_runtime and wow_runtime:FindFirstChild("LootPoints")) or workspace:FindFirstChild("LootPoints")
end

local function wow_getNearestPromptAuto()
    local wow_c = wow_LocalPlayer.Character
    if not wow_c then return end
    local wow_root = wow_c:FindFirstChild("HumanoidRootPart")
    if not wow_root then return end
    local wow_folder = wow_findLootFolderAuto()
    if not wow_folder then return end
    local wow_nearest, wow_dist = nil, math.huge
    for _,wow_v in ipairs(wow_folder:GetDescendants()) do
        if wow_v:IsA("ProximityPrompt") and wow_v.Parent:IsA("BasePart") then
            local wow_d = (wow_v.Parent.Position - wow_root.Position).Magnitude
            if wow_d < wow_dist and wow_d <= 1000 then
                wow_dist = wow_d
                wow_nearest = wow_v
            end
        end
    end
    return wow_nearest, wow_dist
end

local function wow_lootLoopAuto()
    while wow_autoEnabled do
        local wow_prompt, wow_dist = wow_getNearestPromptAuto()
        if wow_prompt then
            local wow_c = wow_LocalPlayer.Character
            if not wow_c then
                task.wait(0.5)
                continue
            end
            local wow_h = wow_c:FindFirstChildOfClass("Humanoid")
            local wow_root = wow_c:FindFirstChild("HumanoidRootPart")
            if wow_h and wow_root then
                if wow_dist > 12 then
                    wow_h:MoveTo(wow_prompt.Parent.Position)
                    task.wait(0.1)
                else
                    fireproximityprompt(wow_prompt)
                    task.wait(0.15)
                end
            end
        end
        task.wait(0.1)
    end
end

local function wow_attackLoopAuto()
    local wow_attackEvents = {
        "SwingTool","UseTool","Attack","Hit","Damage",
        "Swing","Dig","Mine","Chop","ActivateTool"
    }
    while wow_autoEnabled do
        if wow_checkBossExists() then
            local wow_events = wow_ReplicatedStorage:FindFirstChild("Events")
            if wow_events then
                for _,wow_n in ipairs(wow_attackEvents) do
                    local wow_e = wow_events:FindFirstChild(wow_n)
                    if wow_e then pcall(function() wow_e:FireServer() end) end
                end
            end
            local wow_c = wow_LocalPlayer.Character
            if wow_c then
                for _,wow_t in ipairs(wow_c:GetChildren()) do
                    if wow_t:IsA("Tool") then pcall(function() wow_t:Activate() end) end
                end
            end
        end
        task.wait(0.05)
    end
end

local function wow_followBoss()
    if wow_followConn then
        wow_followConn:Disconnect()
        wow_followConn = nil
    end
    
    wow_followConn = wow_RunService.Heartbeat:Connect(function()
        if not wow_autoEnabled then
            wow_followConn:Disconnect()
            wow_followConn = nil
            return
        end
        
        local wow_char = wow_LocalPlayer.Character
        if not wow_char then return end
        
        local wow_humanoid = wow_char:FindFirstChild("Humanoid")
        if not wow_humanoid or wow_humanoid.Health <= 0 then return end
        
        local wow_boss, wow_bossName = wow_findBoss()
        if not wow_boss then return end
        
        local wow_bossPart = wow_boss.PrimaryPart or wow_boss:FindFirstChildWhichIsA("BasePart")
        if not wow_bossPart then return end
        
        local wow_hrp = wow_char:FindFirstChild("HumanoidRootPart")
        if not wow_hrp then return end
        
        local wow_distance = (wow_hrp.Position - wow_bossPart.Position).Magnitude
        if wow_distance > 5 then
            wow_humanoid:MoveTo(wow_bossPart.Position)
        else
            wow_humanoid:MoveTo(wow_hrp.Position)
        end
    end)
end

local function wow_bossLoopAuto()
    while wow_autoEnabled do
        if not wow_hasTeleported then
            local wow_boss, wow_bossName = wow_findBoss()
            if wow_boss then
                local wow_char = wow_LocalPlayer.Character
                if wow_char then
                    local wow_humanoid = wow_char:FindFirstChild("Humanoid")
                    if wow_humanoid and wow_humanoid.Health > 0 then
                        local wow_respawnPos = wow_getRespawnPosition(wow_bossName)
                        if wow_respawnPos then
                            wow_humanoid.Health = 0
                            wow_hasTeleported = true
                            local wow_connection
                            wow_connection = wow_LocalPlayer.CharacterAdded:Connect(function(wow_newChar)
                                task.wait(0.5)
                                local wow_hrp = wow_newChar:WaitForChild("HumanoidRootPart")
                                wow_hrp.CFrame = CFrame.new(wow_respawnPos)
                                wow_connection:Disconnect()
                                task.wait(0.5)
                                wow_followBoss()
                            end)
                        end
                    end
                end
            end
        end
        task.wait(0.1)
    end
end

wow_FarmTab:Toggle("全自动刷所有boss", function(v)
    wow_autoEnabled = v
    wow_hasTeleported = false
    
    if v then
        wow_bossThread = task.spawn(wow_bossLoopAuto)
        wow_lootThread = task.spawn(wow_lootLoopAuto)
        wow_attackThread = task.spawn(wow_attackLoopAuto)
    else
        if wow_bossThread then task.cancel(wow_bossThread) wow_bossThread = nil end
        if wow_lootThread then task.cancel(wow_lootThread) wow_lootThread = nil end
        if wow_attackThread then task.cancel(wow_attackThread) wow_attackThread = nil end
        if wow_followConn then
            wow_followConn:Disconnect()
            wow_followConn = nil
        end
    end
end)

local function wow_findDiamondLootFolder()
    local wow_runtime = workspace:FindFirstChild("Runtime")
    return (wow_runtime and wow_runtime:FindFirstChild("LootPoints")) or workspace:FindFirstChild("LootPoints")
end

local function wow_getNearestDiamond()
    local wow_character = wow_LocalPlayer.Character
    if not wow_character then return end
    local wow_rootPart = wow_character:FindFirstChild("HumanoidRootPart")
    if not wow_rootPart then return end
    
    local wow_lootFolder = wow_findDiamondLootFolder()
    if not wow_lootFolder then return end
    
    local wow_nearestDiamond = nil
    local wow_nearestDistance = math.huge
    
    for _, wow_lootModel in ipairs(wow_lootFolder:GetChildren()) do
        if wow_lootModel:IsA("Model") and wow_lootModel.Name == "Material_Diamond" then
            local wow_basePart = wow_lootModel.PrimaryPart or wow_lootModel:FindFirstChildWhichIsA("BasePart")
            if wow_basePart then
                local wow_distance = (wow_rootPart.Position - wow_basePart.Position).Magnitude
                if wow_distance < wow_nearestDistance then
                    wow_nearestDistance = wow_distance
                    wow_nearestDiamond = wow_lootModel
                end
            end
        end
    end
    
    return wow_nearestDiamond, wow_nearestDistance
end

local function wow_collectDiamondLoop()
    while wow_autoDiamondEnabled do
        local wow_diamondModel, wow_distance = wow_getNearestDiamond()
        
        if wow_diamondModel then
            local wow_character = wow_LocalPlayer.Character
            if not wow_character then
                task.wait(0.5)
                continue
            end
            
            local wow_h = wow_character:FindFirstChildOfClass("Humanoid")
            local wow_root = wow_character:FindFirstChild("HumanoidRootPart")
            
            if wow_h and wow_root then
                if wow_distance > 12 then
                    local wow_basePart = wow_diamondModel.PrimaryPart or wow_diamondModel:FindFirstChildWhichIsA("BasePart")
                    if wow_basePart then
                        wow_h:MoveTo(wow_basePart.Position)
                        task.wait(0.1)
                    end
                else
                    for _, wow_child in ipairs(wow_diamondModel:GetDescendants()) do
                        if wow_child:IsA("ProximityPrompt") then
                            local wow_parent = wow_child.Parent
                            if wow_parent and wow_parent:IsA("BasePart") then
                                local wow_d = (wow_root.Position - wow_parent.Position).Magnitude
                                if wow_d <= 15 then
                                    fireproximityprompt(wow_child)
                                    task.wait(0.15)
                                end
                            end
                        end
                    end
                end
            end
        end
        
        task.wait(0.1)
    end
end

local function wow_diamondAttackLoopAuto()
    local wow_attackEvents = {
        "SwingTool","UseTool","Attack","Hit","Damage",
        "Swing","Dig","Mine","Chop","ActivateTool"
    }
    while wow_autoDiamondEnabled do
        if wow_checkBossExists() then
            local wow_events = wow_ReplicatedStorage:FindFirstChild("Events")
            if wow_events then
                for _,wow_n in ipairs(wow_attackEvents) do
                    local wow_e = wow_events:FindFirstChild(wow_n)
                    if wow_e then pcall(function() wow_e:FireServer() end) end
                end
            end
            local wow_c = wow_LocalPlayer.Character
            if wow_c then
                for _,wow_t in ipairs(wow_c:GetChildren()) do
                    if wow_t:IsA("Tool") then pcall(function() wow_t:Activate() end) end
                end
            end
        end
        task.wait(0.05)
    end
end

local function wow_diamondFollowBoss()
    if wow_diamondFollowConn then
        wow_diamondFollowConn:Disconnect()
        wow_diamondFollowConn = nil
    end
    
    wow_diamondFollowConn = wow_RunService.Heartbeat:Connect(function()
        if not wow_autoDiamondEnabled then
            wow_diamondFollowConn:Disconnect()
            wow_diamondFollowConn = nil
            return
        end
        
        local wow_char = wow_LocalPlayer.Character
        if not wow_char then return end
        
        local wow_humanoid = wow_char:FindFirstChild("Humanoid")
        if not wow_humanoid or wow_humanoid.Health <= 0 then return end
        
        local wow_boss, wow_bossName = wow_findBoss()
        if not wow_boss then return end
        
        local wow_bossPart = wow_boss.PrimaryPart or wow_boss:FindFirstChildWhichIsA("BasePart")
        if not wow_bossPart then return end
        
        local wow_hrp = wow_char:FindFirstChild("HumanoidRootPart")
        if not wow_hrp then return end
        
        local wow_distance = (wow_hrp.Position - wow_bossPart.Position).Magnitude
        if wow_distance > 5 then
            wow_humanoid:MoveTo(wow_bossPart.Position)
        else
            wow_humanoid:MoveTo(wow_hrp.Position)
        end
    end)
end

local function wow_diamondBossLoopAuto()
    while wow_autoDiamondEnabled do
        if not wow_diamondHasTeleported then
            local wow_boss, wow_bossName = wow_findBoss()
            if wow_boss then
                local wow_char = wow_LocalPlayer.Character
                if wow_char then
                    local wow_humanoid = wow_char:FindFirstChild("Humanoid")
                    if wow_humanoid and wow_humanoid.Health > 0 then
                        local wow_respawnPos = wow_getRespawnPosition(wow_bossName)
                        if wow_respawnPos then
                            wow_humanoid.Health = 0
                            wow_diamondHasTeleported = true
                            local wow_connection
                            wow_connection = wow_LocalPlayer.CharacterAdded:Connect(function(wow_newChar)
                                task.wait(0.5)
                                local wow_hrp = wow_newChar:WaitForChild("HumanoidRootPart")
                                wow_hrp.CFrame = CFrame.new(wow_respawnPos)
                                wow_connection:Disconnect()
                                task.wait(0.5)
                                wow_diamondFollowBoss()
                            end)
                        end
                    end
                end
            end
        end
        task.wait(0.1)
    end
end

wow_FarmTab:Toggle("全自动刷所有boss(只捡钻石)", function(v)
    wow_autoDiamondEnabled = v
    wow_diamondHasTeleported = false
    
    if v then
        wow_diamondBossThread = task.spawn(wow_diamondBossLoopAuto)
        wow_diamondAttackThread = task.spawn(wow_diamondAttackLoopAuto)
        wow_collectDiamondThread = task.spawn(wow_collectDiamondLoop)
    else
        if wow_diamondBossThread then task.cancel(wow_diamondBossThread) wow_diamondBossThread = nil end
        if wow_diamondAttackThread then task.cancel(wow_diamondAttackThread) wow_diamondAttackThread = nil end
        if wow_collectDiamondThread then task.cancel(wow_collectDiamondThread) wow_collectDiamondThread = nil end
        if wow_diamondFollowConn then
            wow_diamondFollowConn:Disconnect()
            wow_diamondFollowConn = nil
        end
    end
end)

