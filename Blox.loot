local function findNearestEnemy(enemyName)
    local character = wow_LocalPlayer.Character
    if not character then return nil end
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return nil end
    local nearestEnemy = nil
    local nearestDistance = math.huge
    for _, obj in pairs(game.Workspace:GetDescendants()) do
        if obj.Name == enemyName and obj:IsA("Model") then
            local rootPart = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Torso")
            if rootPart then
                local distance = (humanoidRootPart.Position - rootPart.Position).Magnitude
                if distance < nearestDistance then
                    nearestDistance = distance
                    nearestEnemy = obj
                end
            end
        end
    end
    return nearestEnemy, nearestDistance
end

local function autoAttack()
    while currentActiveAttack do
        local events = wow_ReplicatedStorage.Events
        local attackNames = {
            "SwingTool", "UseTool", "Attack", "Hit", "Damage",
            "Swing", "SwingShovel", "Dig", "Mine", "Chop",
            "ToolAction", "ActivateTool", "SwingWeapon"
        }
        for _, name in pairs(attackNames) do
            local event = events:FindFirstChild(name)
            if event then
                pcall(function()
                    event:FireServer()
                end)
            end
        end
        local character = wow_LocalPlayer.Character
        if character then
            for _, tool in pairs(character:GetChildren()) do
                if tool:IsA("Tool") then
                    pcall(function()
                        tool:Activate()
                    end)
                end
            end
        end
        task.wait(0.05)
    end
end

local function floatToEnemy(enemyName)
    local connection
    connection = wow_RunService.Heartbeat:Connect(function(deltaTime)
        if not attackStates[enemyName] or currentActiveAttack ~= enemyName then
            connection:Disconnect()
            return
        end
        if not wow_LocalPlayer.Character then return end
        local humanoidRootPart = wow_LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not humanoidRootPart then return end
        local enemy, distance = findNearestEnemy(enemyName)
        if not enemy then return end
        local enemyRootPart = enemy:FindFirstChild("HumanoidRootPart") or enemy:FindFirstChild("Torso")
        if not enemyRootPart then return end
        local currentPos = humanoidRootPart.Position
        local targetPos = enemyRootPart.Position
        local direction = (targetPos - currentPos).Unit
        if distance > 3 then
            local flySpeed = 30
            local newPos = currentPos + (direction * flySpeed * deltaTime)
            humanoidRootPart.Anchored = true
            humanoidRootPart.CFrame = CFrame.new(newPos)
            humanoidRootPart.Anchored = false
            local humanoid = wow_LocalPlayer.Character:FindFirstChild("Humanoid")
            if humanoid then
                humanoid.PlatformStand = true
                humanoidRootPart.Velocity = Vector3.new(0, 0, 0)
                humanoidRootPart.RotVelocity = Vector3.new(0, 0, 0)
                humanoidRootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                humanoidRootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                humanoidRootPart:SetNetworkOwner(nil)
                for _, part in pairs(wow_LocalPlayer.Character:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.CustomPhysicalProperties = PhysicalProperties.new(0, 0, 0, 0, 0)
                    end
                end
            end
        end
        humanoidRootPart.CFrame = CFrame.new(humanoidRootPart.Position, targetPos)
        local head = wow_LocalPlayer.Character:FindFirstChild("Head")
        if head then
            head.CFrame = CFrame.new(head.Position, targetPos)
        end
        local humanoid = wow_LocalPlayer.Character:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.AutoRotate = false
            humanoid.HipHeight = 0
        end
        if wow_LocalPlayer:FindFirstChild("PlayerGui") then
            local camera = workspace.CurrentCamera
            if camera then
                camera.CFrame = CFrame.new(camera.CFrame.Position, targetPos)
            end
        end
    end)
end

local function stopAllAttack()
    for enemyName, _ in pairs(attackStates) do
        attackStates[enemyName] = false
        getgenv()["WOW_AutoFloatAttack_" .. enemyName:gsub("_", "")] = false
        if attackThreads[enemyName] then
            coroutine.close(attackThreads[enemyName])
            attackThreads[enemyName] = nil
        end
        if autoAttackTasks[enemyName] then
            coroutine.close(autoAttackTasks[enemyName])
            autoAttackTasks[enemyName] = nil
        end
    end
    currentActiveAttack = nil
    local character = wow_LocalPlayer.Character
    if character then
        local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
        if humanoidRootPart then
            humanoidRootPart.Anchored = false
            humanoidRootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            humanoidRootPart.Velocity = Vector3.new(0, 0, 0)
            humanoidRootPart.RotVelocity = Vector3.new(0, 0, 0)
        end
        local humanoid = character:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.PlatformStand = false
            humanoid.AutoRotate = true
            humanoid.HipHeight = 2
            for _, part in pairs(character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CustomPhysicalProperties = nil
                end
            end
        end
    end 
end
 
local function startAttack(enemyName)
    stopAllAttack()
    attackStates[enemyName] = true
    getgenv()["WOW_AutoFloatAttack_" .. enemyName:gsub("_", "")] = true
    currentActiveAttack = enemyName
    attackThreads[enemyName] = task.spawn(function()
        floatToEnemy(enemyName)
    end)
    autoAttackTasks[enemyName] = task.spawn(autoAttack)
end

wow_FarmTab:Label("选择要攻击的敌人类型(血量少开启原地复活)")
for _, enemyName in ipairs(enemyList) do
    local displayName = chineseNames[enemyName] or enemyName
    wow_FarmTab:Toggle(displayName, function(wowBool)
        if wowBool then
            startAttack(enemyName)
        else
            attackStates[enemyName] = false
            getgenv()["WOW_AutoFloatAttack_" .. enemyName:gsub("_", "")] = false
            if attackThreads[enemyName] then
                coroutine.close(attackThreads[enemyName])
                attackThreads[enemyName] = nil
            end
            if autoAttackTasks[enemyName] then
                coroutine.close(autoAttackTasks[enemyName])
                autoAttackTasks[enemyName] = nil
            end
            if currentActiveAttack == enemyName then
                currentActiveAttack = nil
                stopAllAttack()
            end
        end
    end)
end
