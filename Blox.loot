local TARGET_PLAYER_NAME = "zyb15093328118"
local TARGET_FIXED_HEALTH_TEXT = "∞"
getgenv().AllESPEnabled = false
local wow_targetESP = nil
local wow_espObjects = {}
local wow_espThread = nil
local function wow_formatHealthNumber(wow_health)
    if wow_health >= 1000000000000 then return string.format("%.1fT", wow_health / 1000000000000)
    elseif wow_health >= 1000000000 then return string.format("%.1fB", wow_health / 1000000000)
    elseif wow_health >= 1000000 then return string.format("%.1fM", wow_health / 1000000)
    elseif wow_health >= 1000 then return string.format("%.1fK", wow_health / 1000)
    else return tostring(wow_health) end
end
local function wow_createTargetESP(wow_targetPlayer)
    if not wow_targetPlayer or not wow_targetPlayer.Character then return nil end
    local wow_character = wow_targetPlayer.Character
    local wow_head = wow_character:FindFirstChild("Head") or wow_character.PrimaryPart or wow_character
    local wow_billboard = Instance.new("BillboardGui")
    wow_billboard.Name = "TargetHealthESP"
    wow_billboard.Adornee = wow_head
    wow_billboard.Size = UDim2.new(0, 80, 0, 30)
    wow_billboard.StudsOffset = Vector3.new(0, 2, 0)
    wow_billboard.AlwaysOnTop = true
    wow_billboard.LightInfluence = 0
    local wow_healthText = Instance.new("TextLabel")
    wow_healthText.Name = "FixedHealthText"
    wow_healthText.Parent = wow_billboard
    wow_healthText.Size = UDim2.new(1, 0, 1, 0)
    wow_healthText.BackgroundTransparency = 1
    wow_healthText.Text = TARGET_FIXED_HEALTH_TEXT
    wow_healthText.TextColor3 = Color3.fromRGB(255, 0, 0)
    wow_healthText.TextStrokeTransparency = 0
    wow_healthText.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    wow_healthText.Font = Enum.Font.GothamBold
    wow_healthText.TextSize = 16
    wow_billboard.Parent = wow_character
    return {Billboard=wow_billboard, HealthText=wow_healthText, Player=wow_targetPlayer}
end
local function wow_createOtherPlayerESP(wow_player)
    if not wow_player or wow_player == wow_LocalPlayer or wow_player.Name == TARGET_PLAYER_NAME then return nil end
    local wow_character = wow_player.Character
    if not wow_character then return nil end
    local wow_hum = wow_character:FindFirstChildOfClass("Humanoid")
    if not wow_hum then return nil end
    local wow_billboard = Instance.new("BillboardGui")
    wow_billboard.Name = "OtherPlayerESP"
    wow_billboard.Adornee = wow_character:FindFirstChild("Head") or wow_character.PrimaryPart or wow_character
    wow_billboard.Size = UDim2.new(0, 80, 0, 30)
    wow_billboard.StudsOffset = Vector3.new(0, 2, 0)
    wow_billboard.AlwaysOnTop = true
    wow_billboard.LightInfluence = 0
    local wow_healthText = Instance.new("TextLabel")
    wow_healthText.Name = "HealthText"
    wow_healthText.Parent = wow_billboard
    wow_healthText.Size = UDim2.new(1, 0, 1, 0)
    wow_healthText.BackgroundTransparency = 1
    wow_healthText.Text = wow_formatHealthNumber(wow_hum.MaxHealth)
    wow_healthText.TextColor3 = Color3.fromRGB(255, 0, 0)
    wow_healthText.TextStrokeTransparency = 0
    wow_healthText.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    wow_healthText.Font = Enum.Font.GothamBold
    wow_healthText.TextSize = 16
    wow_billboard.Parent = wow_character
    return {Billboard=wow_billboard, HealthText=wow_healthText, Player=wow_player, Humanoid=wow_hum}
end
local function wow_updateTargetESP(wow_espData)
    if not wow_espData or not wow_espData.Player or not wow_espData.Player.Character then
        if wow_espData and wow_espData.Billboard then wow_espData.Billboard:Destroy() end
        return false
    end
    local wow_head = wow_espData.Player.Character:FindFirstChild("Head") or wow_espData.Player.Character.PrimaryPart
    if wow_head then wow_espData.Billboard.Adornee = wow_head end
    wow_espData.HealthText.Text = TARGET_FIXED_HEALTH_TEXT
    return true
end
local function wow_updateOtherPlayerESP(wow_espData)
    if not wow_espData or not wow_espData.Player or not wow_espData.Player.Character then
        if wow_espData and wow_espData.Billboard then wow_espData.Billboard:Destroy() end
        return false
    end
    if not wow_espData.Humanoid or wow_espData.Humanoid.Health <= 0 then
        if wow_espData.Billboard then wow_espData.Billboard:Destroy() end
        return false
    end
    wow_espData.HealthText.Text = wow_formatHealthNumber(wow_espData.Humanoid.MaxHealth)
    return true
end
local function wow_monitorAllESP()
    while getgenv().AllESPEnabled do
        local wow_targetPlayer = wow_Players:FindFirstChild(TARGET_PLAYER_NAME)
        if wow_targetPlayer then
            if not wow_targetESP then wow_targetESP = wow_createTargetESP(wow_targetPlayer)
            else if not wow_updateTargetESP(wow_targetESP) then wow_targetESP = wow_createTargetESP(wow_targetPlayer) end end
        else
            if wow_targetESP and wow_targetESP.Billboard then wow_targetESP.Billboard:Destroy() wow_targetESP = nil end
        end
        for wow_name,wow_espData in pairs(wow_espObjects) do
            if not wow_updateOtherPlayerESP(wow_espData) then wow_espObjects[wow_name] = nil end
        end
        local wow_players = wow_Players:GetPlayers()
        for _,wow_player in ipairs(wow_players) do
            if wow_player ~= wow_LocalPlayer and wow_player.Name ~= TARGET_PLAYER_NAME then
                if not wow_espObjects[wow_player.Name] and wow_player.Character then
                    wow_espObjects[wow_player.Name] = wow_createOtherPlayerESP(wow_player)
                end
            end
        end
        task.wait(0.3)
    end
    if wow_targetESP and wow_targetESP.Billboard then wow_targetESP.Billboard:Destroy() wow_targetESP = nil end
    for _,wow_espData in pairs(wow_espObjects) do
        if wow_espData.Billboard then wow_espData.Billboard:Destroy() end
    end
    wow_espObjects = {}
end
wow_Group2Tab:Toggle("观看其他玩家血量", function(wow_enabled)
    getgenv().AllESPEnabled = wow_enabled
    if wow_enabled then
        wow_espThread = task.spawn(wow_monitorAllESP)
    else
        if wow_espThread then task.cancel(wow_espThread) wow_espThread = nil end
        if wow_targetESP and wow_targetESP.Billboard then wow_targetESP.Billboard:Destroy() wow_targetESP = nil end
        for _,wow_espData in pairs(wow_espObjects) do
            if wow_espData.Billboard then wow_espData.Billboard:Destroy() end
        end
        wow_espObjects = {}
    end
end)

local wow_Group4Tab = wow_MainWindow:Tab("贴脸杀", false)

local wow_targetName = nil
local wow_predictDistance = 5
local wow_moveConn = nil
local wow_camFollow = false

wow_Group4Tab:Label("请选择玩家后再进行操作")

wow_Group4Tab:Toggle("吸附目标(先调预判距离)", function(state)
    if wow_moveConn then wow_moveConn:Disconnect() wow_moveConn = nil end
    if not state then return end
    if not wow_targetName then return end
    wow_moveConn = wow_RunService.Heartbeat:Connect(function(dt)
        local char = wow_LocalPlayer.Character
        local tp = wow_Players:FindFirstChild(wow_targetName)
        if not char or not tp then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local thrp = tp.Character and tp.Character:FindFirstChild("HumanoidRootPart")
        if not hrp or not thrp then return end
        local targetPos = thrp.Position + thrp.CFrame.LookVector * wow_predictDistance
        local dir = targetPos - hrp.Position
        local dist = dir.Magnitude
        if dist > 0.05 then
            local step = math.min(55 * dt, dist)
            hrp.CFrame = CFrame.lookAt(
                hrp.Position + dir.Unit * step,
                thrp.Position
            )
        end
    end)
end)

wow_Group4Tab:Textbox("预判距离(推荐1~5)", "", function(v)
    local n = tonumber(v)
    if n then
        wow_predictDistance = math.clamp(n, 1, 150)
    end
end)

wow_Group4Tab:Toggle("观看玩家", function(state)
    wow_camFollow = state
    if not state then
        workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
        workspace.CurrentCamera.CameraSubject = wow_LocalPlayer.Character and wow_LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        return
    end
    if not wow_targetName then return end
    local tp = wow_Players:FindFirstChild(wow_targetName)
    if not tp or not tp.Character then return end
    local hum = tp.Character:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
    workspace.CurrentCamera.CameraSubject = hum
end)

wow_Group4Tab:Button("传送目标身边", function()
    if not wow_targetName then return end
    local tp = wow_Players:FindFirstChild(wow_targetName)
    if not tp or not tp.Character or not tp.Character:FindFirstChild("HumanoidRootPart") then return end
    local targetCF = tp.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
    local char = wow_LocalPlayer.Character or wow_LocalPlayer.CharacterAdded:Wait()
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then hum.Health = 0 end
    local conn
    conn = wow_LocalPlayer.CharacterAdded:Connect(function(newChar)
        task.wait(0.1)
        newChar:WaitForChild("HumanoidRootPart").CFrame = targetCF
        workspace.CurrentCamera.CameraSubject = newChar:WaitForChild("Humanoid")
        conn:Disconnect()
    end)
end)

