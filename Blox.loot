local wow_bossLabels = {}
local function wow_getNode(wow_path)
    local wow_node = workspace
    for _,wow_k in ipairs(wow_path) do 
        wow_node=wow_node:FindFirstChild(wow_k) 
        if not wow_node then return nil end 
    end
    return wow_node
end

local function wow_createBossDisplay()
    for _,wow_bossInfo in ipairs(wow_TARGETS_LIST) do
        local wow_name = wow_bossInfo.name
        local wow_path = wow_bossInfo.path
        local wow_exists = wow_getNode(wow_path)
        local wow_text = wow_name.." → "..(wow_exists and "已刷新✅️" or "无刷新❌")
        if wow_bossLabels[wow_name] then 
            wow_bossLabels[wow_name]:Remove() 
        end
        wow_bossLabels[wow_name] = wow_Group1Tab:Label(wow_text)
    end
end

if wow_TARGETS_LIST then
    wow_createBossDisplay()
    task.spawn(function() 
        while task.wait(1) do 
            wow_createBossDisplay() 
        end 
    end)
end
if game.PlaceId == 120704669141193 then

local TARGET_RESPAWN_POSITION_SPIDER = Vector3.new(-74, 45, -123)
local TARGET_RESPAWN_CFRAME_SPIDER = CFrame.new(TARGET_RESPAWN_POSITION_SPIDER)

local function instantRespawnAtPositionSpider()
    local character = wow_LocalPlayer.Character
    if not character then
        character = wow_LocalPlayer.CharacterAdded:Wait()
    end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid and humanoid.Health > 0 then
        humanoid.Health = 0
    end
    
    local connection
    connection = wow_LocalPlayer.CharacterAdded:Connect(function(newCharacter)
        task.wait(0.1)
        local humanoidRootPart = newCharacter:WaitForChild("HumanoidRootPart", 2)
        if humanoidRootPart then
            humanoidRootPart.CFrame = TARGET_RESPAWN_CFRAME_SPIDER
        end
        if connection then
            connection:Disconnect()
        end
    end)
    
    if humanoid and humanoid.Health <= 0 then
        task.wait(0.5)
        if character.Parent then
            character:BreakJoints()
        end
    end
end

