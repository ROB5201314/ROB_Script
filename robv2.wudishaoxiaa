local animIndex = 4
for i, v in ipairs(animations) do
    if v.id == currentAnimId then
        animIndex = i
        break
    end
end
nextBtn.MouseButton1Click:Connect(function()
    animIndex = animIndex % #animations + 1
    currentAnimId = animations[animIndex].id
    animLabel.Text = animations[animIndex].name
    if flying then playAnimation(currentAnimId) end
end)

flyBtn.MouseButton1Click:Connect(function()
    if flying then stopFly() else startFly() end
end)
boostBtn.MouseButton1Click:Connect(function()
    if not flying then return end
    setBoost(not boosting)
end)

upBtn.MouseButton1Down:Connect(function()
    upPressed = true
end)
upBtn.MouseButton1Up:Connect(function()
    upPressed = false
end)
upBtn.MouseLeave:Connect(function()
    upPressed = false
end)

downBtn.MouseButton1Down:Connect(function()
    downPressed = true
end)
downBtn.MouseButton1Up:Connect(function()
    downPressed = false
end)
downBtn.MouseLeave:Connect(function()
    downPressed = false
end)

local folded = false
foldBtn.MouseButton1Click:Connect(function()
    folded = not folded
    if folded then
        content.Visible = false
        mainFrame.Size = UDim2.new(0, 190, 0, 36)
        foldBtn.Text = "+"
    else
        content.Visible = true
        mainFrame.Size = UDim2.new(0, 190, 0, 150)
        foldBtn.Text = "-"
    end
end)

local dragging = false
local dragStart, frameStart
titleBar.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        frameStart = mainFrame.Position
    end
end)
UserInputService.InputChanged:Connect(function(input, gpe)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(frameStart.X.Scale, frameStart.X.Offset + delta.X,
                                       frameStart.Y.Scale, frameStart.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input, gpe)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.F then
        if flying then stopFly() else startFly() end
    elseif input.KeyCode == Enum.KeyCode.G then
        if flying then setBoost(true) end
    end
end)
UserInputService.InputEnded:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.G then
        setBoost(false)
    end
end)

RunService.RenderStepped:Connect(function()
    if flying then updateFlight() end
end)

player.CharacterAdded:Connect(function()
    if flying then stopFly() end
end)

local rs = game:GetService("RunService")
local hb = rs.Heartbeat
local rsd = rs.RenderStepped
local lp = game.Players.LocalPlayer
local z = Vector3.zero
local function antiFall(c)
    local r = c:FindFirstChild("HumanoidRootPart")
    if r then
        local con
        con = hb:Connect(function()
            if not r.Parent then con:Disconnect() end
            if not flying then
                local v = r.AssemblyLinearVelocity
                r.AssemblyLinearVelocity = z
                rsd:Wait()
                r.AssemblyLinearVelocity = v
            end
        end)
    end
end
antiFall(lp.Character)
lp.CharacterAdded:Connect(antiFall)

playAnimation(currentAnimId)
