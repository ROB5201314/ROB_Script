local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local player = Players.LocalPlayer

local flying = false
local boosting = false
local bodyVel = nil
local bodyGyro = nil
local currentAnim = nil
local currentAnimId = "132783162476851"

local BASE_SPEED = 50
local BOOST_SPEED = 100
local currentSpeed = BASE_SPEED
local VERTICAL_SPEED = 30
local upPressed = false
local downPressed = false

local animations = {
    {name = "DefaultIdle", id = "718076987"},
    {name = "MustacheMark", id = "92365791487740"},
    {name = "Thragg", id = "85064366773524"},
    {name = "RelaxedFly", id = "132783162476851"}
}

local function playAnimation(animId)
    if currentAnim then
        currentAnim:Stop()
        currentAnim:Destroy()
        currentAnim = nil
    end
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    local anim = Instance.new("Animation")
    anim.AnimationId = "rbxassetid://" .. animId
    local track = hum:LoadAnimation(anim)
    track.Looped = true
    track:Play()
    currentAnim = track
end

local function updateFlight()
    if not flying then return end
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp then return end

    local moveDir = hum.MoveDirection
    local camera = workspace.CurrentCamera
    local camCF = camera.CFrame

    local relative = camCF:VectorToObjectSpace(moveDir)
    local horizontal = camCF.RightVector * relative.X - camCF.LookVector * relative.Z
    if horizontal.Magnitude > 0 then
        horizontal = horizontal.Unit
    end
    horizontal = horizontal * currentSpeed

    local vertical = 0
    if upPressed then
        vertical = VERTICAL_SPEED
    elseif downPressed then
        vertical = -VERTICAL_SPEED
    elseif UserInputService:IsKeyDown(Enum.KeyCode.Space) then
        vertical = VERTICAL_SPEED
    elseif UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
        vertical = -VERTICAL_SPEED
    end

    bodyVel.Velocity = Vector3.new(horizontal.X, vertical, horizontal.Z)

    local forward = Vector3.new(camCF.LookVector.X, 0, camCF.LookVector.Z).Unit
    if forward.Magnitude < 0.001 then forward = Vector3.new(0,0,1) end
    bodyGyro.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + forward, Vector3.new(0,1,0))
    hum.AutoRotate = false
end

local function startFly()
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end
    if bodyVel then bodyVel:Destroy() end
    if bodyGyro then bodyGyro:Destroy() end
    bodyVel = Instance.new("BodyVelocity")
    bodyVel.MaxForce = Vector3.new(1e9, 1e9, 1e9)
    bodyVel.Parent = hrp
    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
    bodyGyro.P = 10000
    bodyGyro.D = 500
    bodyGyro.Parent = hrp
    hum.PlatformStand = true
    flying = true
    currentSpeed = boosting and BOOST_SPEED or BASE_SPEED
    playAnimation(currentAnimId)
    flyBtn.Text = "UNFLY"
    flyBtn.BackgroundColor3 = Color3.fromRGB(220, 60, 60)
end

local function stopFly()
    if bodyVel then bodyVel:Destroy() end
    if bodyGyro then bodyGyro:Destroy() end
    bodyVel, bodyGyro = nil, nil
    local char = player.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.PlatformStand = false
            hum.AutoRotate = true
        end
    end
    if currentAnim then
        currentAnim:Stop()
        currentAnim:Destroy()
        currentAnim = nil
    end
    flying = false
    boosting = false
    currentSpeed = BASE_SPEED
    flyBtn.Text = "FLY"
    flyBtn.BackgroundColor3 = Color3.fromRGB(220, 60, 60)
    boostBtn.Text = "BOOST"
    boostBtn.BackgroundColor3 = Color3.fromRGB(0, 160, 255)
end

local function setBoost(active)
    boosting = active
    if flying then
        currentSpeed = boosting and BOOST_SPEED or BASE_SPEED
        boostBtn.Text = boosting and "BOOST" or "BOOST"
        boostBtn.BackgroundColor3 = boosting and Color3.fromRGB(0, 200, 255) or Color3.fromRGB(0, 160, 255)
    end
end

